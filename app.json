{
  "expo": {
    "name": "FinanzasPro",
    "slug": "finanzaspro",
    "version": "1.0.0",
    "scheme": "com.finanzaspro.app",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2547"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3C6E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.finanzaspro.app",
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "com.googleusercontent.apps.609918113890-l4m6nbkmavsmpob8ll99s0vqo1aqjcp6"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "SEND",
          "data": [
            {
              "mimeType": "image/*"
            }
          ],
          "category": [
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finanzaspro.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-web-browser",
      "expo-sharing",
      "expo-font",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "91d31b68-ee98-47c7-ba4c-a77d12f33da0"
      }
    }
  }
}
